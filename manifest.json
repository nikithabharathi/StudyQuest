{
  "manifest_version": 3,
  "name": "StudyQuest",
  "description": "Privacy-first adaptive study companion that intervenes gently at distraction moments.",
  "version": "1.0.0",

  "permissions": [
    "tabs",
    "storage",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}